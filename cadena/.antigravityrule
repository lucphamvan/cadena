## API & Data Fetching

- API calls qua **service layer** (`services/*.service.ts`) — KHÔNG gọi axios trực tiếp trong component
- **Luôn dùng `async/await`** — KHÔNG dùng `.then()` chains
- Dùng **React Query** (`@tanstack/react-query`) cho tất cả server state
- Custom hooks trong `hooks/` hoặc `features/[name]/hooks/`

```ts
// ✅ Service pattern
export const employeeService = {
  getById: async (id: string): Promise<Employee> => {
    const response = await api.get<Employee>(`/employees/${id}`);
    return response.data;
  },
} as const;

// ✅ React Query hook
export const useEmployee = (id: string) => {
  return useQuery({
    queryKey: ["employee", id],
    queryFn: async () => await employeeService.getById(id),
    enabled: !!id,
  });
};
```

