# =============================================================
# Cadena — Centralized Environment Variables
# Copy this file: cp .env.example .env   (then edit values)
# =============================================================

# ---- General ----
APP_ENV=production

# ---- CORS ----
# In production, replace * with your actual domain(s)
CORS_ALLOWED_ORIGINS=*

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=employee_portal
POSTGRES_SSLMODE=disable
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PASSWORD=
REDIS_PORT=6379

# ---- Backend (Go) ----
BACKEND_PORT=8080
LOG_LEVEL=info
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_a_strong_random_key

# ---- Frontend (React) ----
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080/api
VITE_APP_NAME=Employee Portal
