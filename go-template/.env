# Môi trường chạy application (development, staging, production)
APP_ENV=production

# API CORS, ở production bạn nên đổi thành tên miền, VD: https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=*

# -----------------
# POSTGRES DATABASE
# -----------------
# Nếu chạy App không thông qua Docker (go run main.go), set POSTGRES_HOST=localhost
# Nếu chạy full hệ thống bằng Docker Compose, set POSTGRES_HOST=postgres (tên container)
POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=employee_portal
POSTGRES_SSLMODE=disable

# -----------------
# REDIS CACHE
# -----------------
REDIS_HOST=redis
REDIS_PASSWORD=

# -----------------
# CẤU HÌNH HỆ THỐNG
# -----------------
# Mức độ log hệ thống. Ở production thường dùng `info` hoặc `warn` để tối ưu
LOG_LEVEL=info

# JWT Authorization Secret. Bắt buộc thay đổi ở môi trường Production (ko đc là default)
JWT_SECRET=my_custom_production_secret_key_8h3d892h3d
